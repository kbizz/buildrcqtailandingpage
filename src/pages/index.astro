---
import BaseLayout from "@layouts/BaseLayout.astro";
import InsightConsole from "@components/InsightConsole";
import LiveCourtWall from "@components/LiveCourtWall";
import NewsletterForm from "@components/NewsletterForm.astro";
import { courts, matches, siteConfig, visualAssets } from "@data/rcqt";
import { withBase } from "@lib/routes";
---

<BaseLayout
  title="RCQT.AI | Cinematic tennis intelligence for college programs"
  description="RCQT.AI turns live tennis court cameras into fan broadcasts, searchable team video libraries, and AI coaching intelligence."
  bodyClass="site-shell"
>
  <section class="hero hero--landing" style={`--hero-image: url('${visualAssets.heroCourt}')`}>
    <div class="hero__media" aria-hidden="true">
      <div class="hero__court-map">
        <span></span><span></span><span></span><span></span>
      </div>
      <div class="hero__ticker">
        <span>COURT 1: first-strike pressure +14%</span>
        <span>COURT 2: doubles poach window open</span>
        <span>COURT 4: clip ready for player report</span>
      </div>
    </div>
    <div class="hero__content">
      <p class="eyebrow">Live tennis intelligence for the college market</p>
      <h1>Make every court feel like the match everyone understands.</h1>
      <p class="hero__lede">
        RCQT.AI turns facility cameras into cinematic live streams, searchable match libraries,
        broadcast graphics, and AI coaching context for teams ready to make tennis feel legible,
        emotional, and obsessively useful.
      </p>
      <div class="hero__actions">
        <a class="button button--primary" href={siteConfig.demoUrl}>Schedule a demo</a>
        <a class="button button--ghost" href={withBase("/demo/vanderbilt/")}>View team page</a>
      </div>
    </div>
  </section>

  <section class="story-band story-band--shock">
    <div class="section-kicker">
      <span>Why RCQT.AI exists</span>
      <strong>College tennis has live courts. It needs a live story.</strong>
    </div>
    <div class="story-grid">
      <article>
        <span>01</span>
        <h2>The cameras are already there.</h2>
        <p>
          Programs have installed court cameras for years, but the audience still sees tennis as
          disconnected boxes of video. RCQT turns each feed into a coordinated match center.
        </p>
      </article>
      <article>
        <span>02</span>
        <h2>The angle matters.</h2>
        <p>
          The product is built around better mount height, camera selection, and viewing geometry
          so tennis points are easier to watch, clip, search, and explain.
        </p>
      </article>
      <article>
        <span>03</span>
        <h2>The match has a memory.</h2>
        <p>
          Every player, point pattern, team score, and conference implication can become context
          for fans, coaches, players, newsletters, and post-match reports.
        </p>
      </article>
    </div>
  </section>

  <section class="split-section split-section--broadcast">
    <div>
      <p class="eyebrow">Fan-facing product</p>
      <h2>Not a sports page. A match operating system wearing a broadcast skin.</h2>
      <p>
        A team page can carry court previews, public streams, player pages, team scoring, merch,
        social links, match stakes, and newsletter capture without asking fans to understand the
        chaos of six simultaneous matches.
      </p>
      <div class="proof-strip">
        <span><strong>6</strong> courts visible</span>
        <span><strong>24/7</strong> searchable video</span>
        <span><strong>AI</strong> commentary layer</span>
      </div>
      <a class="text-link" href={withBase("/demo/vanderbilt/")}>Open the Vanderbilt-themed demo</a>
    </div>
    <LiveCourtWall courts={courts.slice(0, 4)} compact client:load />
  </section>

  <section class="cinema-section">
    <div class="cinema-section__copy">
      <p class="eyebrow">The secret sauce</p>
      <h2>Video library first. Intelligence everywhere after.</h2>
      <p>
        The team grants players access to a searchable archive of everything recorded on its courts.
        Each clicked match can become a living page: video, stats, opponent context, player trends,
        and an AI assistant that knows what the player needs to do to win.
      </p>
    </div>
    <div class="cinema-rail" aria-label="RCQT product layers">
      <article>
        <span>Live</span>
        <h3>Public match stream</h3>
        <p>{matches[0].stakes}</p>
      </article>
      <article>
        <span>Index</span>
        <h3>Searchable match library</h3>
        <p>Find every serve pattern, break point, doubles shift, player, court, and opponent.</p>
      </article>
      <article>
        <span>Learn</span>
        <h3>Conversational coaching</h3>
        <p>Ask what changed, what mattered, and what plan gives a player the cleanest path forward.</p>
      </article>
    </div>
  </section>

  <section class="split-section split-section--ai">
    <div>
      <p class="eyebrow">AI and broadcast graphics</p>
      <h2>Computer vision is not the feature. The feature is what the match becomes.</h2>
      <p>
        RCQT.AI can surface head-to-head context, serve breakdowns, lineup pressure, momentum,
        and tactical coaching language in the same place where fans are already watching.
      </p>
    </div>
    <InsightConsole client:load />
  </section>

  <section class="cta-band" id="newsletter">
    <div>
      <p class="eyebrow">For college programs ready to look inevitable</p>
      <h2>Bring broadcast energy and coaching intelligence to every court.</h2>
    </div>
    <div class="cta-band__actions">
      <a class="button button--primary" href={siteConfig.demoUrl}>Schedule a demo</a>
      <NewsletterForm compact />
    </div>
  </section>
</BaseLayout>
